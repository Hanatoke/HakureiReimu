dotnet_naming_rule.렷俚뙈냥逃_should_be_탕薑엥틈畇랬.style = 탕薑엥틈畇랬

# 륜뵀방렀

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, friend, private, protected, protected_friend, private_protected
dotnet_naming_symbols.interface.required_modifiers = 

dotnet_naming_symbols.잚謹.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.잚謹.applicable_accessibilities = public, friend, private, protected, protected_friend, private_protected
dotnet_naming_symbols.잚謹.required_modifiers = 

dotnet_naming_symbols.렷俚뙈냥逃.applicable_kinds = property, event, method
dotnet_naming_symbols.렷俚뙈냥逃.applicable_accessibilities = public, friend, private, protected, protected_friend, private_protected
dotnet_naming_symbols.렷俚뙈냥逃.required_modifiers = 

# 츱츰湳駕

dotnet_naming_style.鹿_i_역迦.required_prefix = I
dotnet_naming_style.鹿_i_역迦.required_suffix = 
dotnet_naming_style.鹿_i_역迦.word_separator = 
dotnet_naming_style.鹿_i_역迦.capitalization = pascal_case


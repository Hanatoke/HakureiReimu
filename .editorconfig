dotnet_naming_style.탕薑엥틈畇랬.required_suffix = 
dotnet_naming_style.탕薑엥틈畇랬.word_separator = 
dotnet_naming_style.탕薑엥틈畇랬.capitalization = pascal_case

dotnet_naming_style.탕薑엥틈畇랬.required_prefix = 
dotnet_naming_style.탕薑엥틈畇랬.required_suffix = 
